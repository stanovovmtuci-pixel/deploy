# Force LF line endings for all text files (cross-platform repo)
* text=auto eol=lf

# Shell scripts and Python -- always LF
*.sh    text eol=lf
*.py    text eol=lf
*.tpl   text eol=lf
*.conf  text eol=lf
*.cfg   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.js    text eol=lf
*.service text eol=lf
*.timer   text eol=lf

# Binary files (none currently, but for the future)
*.png   binary
*.jpg   binary
*.gz    binary

# Don't mess with this
.gitignore text eol=lf
.gitattributes text eol=lf
