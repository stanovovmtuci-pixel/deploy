# /etc/fail2ban/jail.local
# Generated by deploy-kit (external/) — DO NOT EDIT BY HAND
# Year:    {{CURRENT_YEAR}}
# Node:    {{NODE_HOSTNAME}}
# RUN_ID:  {{RUN_ID}}
#
# Two jails:
#   sshd     — bans IPs that fail SSH auth
#   recidive — meta-jail, bans IPs that have been banned by other jails repeatedly

[DEFAULT]
# Use systemd journal as source (no /var/log/auth.log on modern Ubuntu)
backend = systemd

# Default ban tuning (overridden per-jail below)
bantime  = 3600
findtime = 600
maxretry = 5

# Whitelist — never banned
ignoreip = {{F2B_IGNORE_IPS}}

# Action: drop with iptables, not REJECT (silent drop preferred)
banaction         = iptables-multiport
banaction_allports = iptables-allports

[sshd]
enabled  = true
port     = {{SSHD_PORT}}
filter   = sshd
maxretry = {{F2B_SSHD_MAXRETRY}}
findtime = {{F2B_SSHD_FINDTIME}}
bantime  = {{F2B_SSHD_BANTIME}}

[recidive]
enabled  = true
filter   = recidive
logpath  = /var/log/fail2ban.log
banaction = %(banaction_allports)s
maxretry = {{F2B_RECIDIVE_MAXRETRY}}
findtime = {{F2B_RECIDIVE_FINDTIME}}
bantime  = {{F2B_RECIDIVE_BANTIME}}