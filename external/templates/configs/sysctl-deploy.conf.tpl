# /etc/sysctl.d/99-deploy.conf
# Generated by deploy-kit (external/) — DO NOT EDIT BY HAND
# Year:    {{CURRENT_YEAR}}
# Node:    {{NODE_HOSTNAME}}
# RUN_ID:  {{RUN_ID}}
#
# Network tuning for: IP forwarding (required for AWG), BBR congestion control,
# TCP Fast Open, MTU probing.

# --- IPv4 forwarding ---
net.ipv4.ip_forward = {{SYSCTL_IPV4_FORWARDING}}

# --- IPv6 forwarding (required for AWG over fd10::/64) ---
net.ipv6.conf.all.forwarding = {{SYSCTL_IPV6_FORWARDING}}
net.ipv6.conf.default.forwarding = {{SYSCTL_IPV6_FORWARDING}}

# --- TCP congestion control: BBR (faster than default cubic on lossy links) ---
# fq qdisc is required for BBR; setting both together to avoid order issues.
net.core.default_qdisc = fq
net.ipv4.tcp_congestion_control = bbr

# --- TCP Fast Open (3 = both incoming and outgoing) ---
net.ipv4.tcp_fastopen = {{SYSCTL_TCP_FASTOPEN}}

# --- MTU probing: detect path MTU blackholes (helps with AWG/WARP overlays) ---
net.ipv4.tcp_mtu_probing = 1

# --- Don't accept router advertisements on the host
#     (we manage routes explicitly via awg-quick / iptables) ---
net.ipv6.conf.all.accept_ra = 0
net.ipv6.conf.default.accept_ra = 0

# --- ICMP redirects (security) ---
net.ipv4.conf.all.accept_redirects = 0
net.ipv4.conf.all.send_redirects = 0
net.ipv6.conf.all.accept_redirects = 0

# --- Reverse path filtering (loose mode for asymmetric routes via AWG) ---
net.ipv4.conf.all.rp_filter = 2
net.ipv4.conf.default.rp_filter = 2

# --- Increase conntrack table for many concurrent peers ---
net.netfilter.nf_conntrack_max = 131072

# --- Disable source routing (security) ---
net.ipv4.conf.all.accept_source_route = 0
net.ipv6.conf.all.accept_source_route = 0